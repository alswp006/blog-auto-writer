# ============================================
# 필수 — AI 글 생성의 핵심
# ============================================

# OpenAI API 키 (글 생성, 사진 분석, 키워드 추출 등 모든 AI 기능)
OPENAI_API_KEY=
# 사용할 OpenAI 모델 (기본: gpt-4o-mini, 추천: gpt-4o 또는 gpt-5)
OPENAI_MODEL=gpt-4o-mini
# 사진 분석 전용 모델 (미설정 시 OPENAI_MODEL 사용, 빠른 모델 권장)
OPENAI_VISION_MODEL=

# ============================================
# 선택 — Anthropic Claude (메인 생성 모델 대안)
# ============================================

# LLM 제공자 선택 (openai 또는 anthropic, 기본: openai)
LLM_PROVIDER=openai
# Anthropic API 키 (LLM_PROVIDER=anthropic 일 때 필수)
# 발급: https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Anthropic 모델 (기본: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# ============================================
# 선택 — Gemini (사진 분석 + 에이전트 리서치)
# ============================================

# Google Gemini API 키 (사진 분석 Vision 전용 — 텍스트 작업은 OpenAI 사용)
# 발급: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Gemini Vision 모델 (기본: gemini-2.0-flash — 사진 묘사/캡션에만 사용)
GEMINI_VISION_MODEL=gemini-2.0-flash

# ============================================
# 선택 — 문체 학습 고도화
# ============================================

# 과거 포스트 참조 개수 (기본: 2, 대형 컨텍스트 모델 사용 시 10~20 권장)
# 많을수록 사용자 문체를 더 정확하게 모방합니다
STYLE_CONTEXT_POSTS=2

# ============================================
# 선택 — 얼굴 모자이크 (Google Cloud Vision API)
# ============================================

# Google Cloud API 키 (Cloud Vision API 활성화 필요)
# 발급: https://console.cloud.google.com/apis/credentials
# 월 1,000장 무료, 이후 $1.50/1,000장
GOOGLE_CLOUD_API_KEY=

# ============================================
# 권장 — 장소 검색 & 글 품질 향상
# ============================================

# 네이버 Open API (장소 검색 자동완성 + 블로그 참고 데이터)
# 발급: https://developers.naver.com/apps
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Google Custom Search (블로그 참고 데이터 보강, 없어도 동작)
# 발급: https://programmablesearchengine.google.com
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# 원화→달러 환율 (영어 글에서 가격 변환용, 기본: 1300)
KRW_USD_RATE=1300

# ============================================
# 선택 — 블로그 발행 연동
# ============================================

# 티스토리 발행
# 발급: https://www.tistory.com/guide/api/manage/register
TISTORY_APP_ID=
TISTORY_SECRET_KEY=
TISTORY_ACCESS_TOKEN=
TISTORY_BLOG_NAME=

# 워드프레스 발행
WORDPRESS_URL=
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=

# 미디엄 발행
MEDIUM_INTEGRATION_TOKEN=

# ============================================
# 선택 — 분석 & 수익화
# ============================================

# Google Analytics 추적 ID
NEXT_PUBLIC_GA_ID=

# Google AdSense 클라이언트 ID (광고 표시용)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# Google AdSense 수익 조회 API (관리자 대시보드용)
GOOGLE_ADSENSE_CLIENT_ID=
GOOGLE_ADSENSE_CLIENT_SECRET=
GOOGLE_ADSENSE_REFRESH_TOKEN=

# ============================================
# 선택 — 사이트 설정
# ============================================

# 사이트 URL (SEO, OG 이미지, 사이트맵용)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# 사이트 이름 (SEO, 네비게이션 표시용)
NEXT_PUBLIC_SITE_NAME=Blog Auto Writer
# 앱 URL (Stripe 리다이렉트용)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 관리자 이메일 (쉼표로 구분, 관리자 페이지 접근 권한)
ADMIN_EMAILS=

# 예약 발행 크론 시크릿 (외부에서 /api/cron/publish 호출 시 인증용)
CRON_SECRET=

# ============================================
# Stripe 결제 — 사용하지 않음 (비워두세요)
# ============================================
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
